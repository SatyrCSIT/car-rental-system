# ===== ตัวอย่างค่า config สำหรับ Docker (คัดลอกไฟล์นี้เป็น .env แล้วใส่ค่าจริง) =====
# ไฟล์นี้ commit ขึ้น git ได้ (ไม่มีรหัสจริง) ส่วน .env ห้าม commit

# ฐานข้อมูล
DB_DATABASE=project_carrent
DB_USERNAME=carrental
DB_PASSWORD=change_this_password
DB_ROOT_PASSWORD=change_this_root_password
DB_PORT=3306

# phpMyAdmin (เปิดที่ http://localhost:8080)
PMA_PORT=8080
